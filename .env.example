# Настройки интеграции с Telegram Bot для сбора лидов с сайта ЛЕОНИКА
# Скопируйте этот файл под именем '.env' в корень проекта и укажите ваши реальные ключи.

# Токен вашего бота (получается у @BotFather)
VITE_TELEGRAM_BOT_TOKEN=your_bot_token_here

# ID вашего чата, группы или канала, куда отправлять заявки (например, 123456789 или @channel_username)
# Чтобы узнать свой chat_id, можно написать боту @userinfobot
VITE_TELEGRAM_CHAT_ID=your_chat_id_here
